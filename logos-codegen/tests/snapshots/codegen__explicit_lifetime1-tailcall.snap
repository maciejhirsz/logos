                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                        ___,
                    ]
                };
                offset += 1;
                match TABLE[byte as usize] {
                    LogosNextState::State1 => {
                        return state1(lex, offset, context);
                    }
                    LogosNextState::State2 => {
                        return state2(lex, offset, context);
                    }
                    LogosNextState::State3 => {
                        return state3(lex, offset, context);
                    }
                    LogosNextState::State4 => {
                        return state4(lex, offset, context);
                    }
                    LogosNextState::___ => {}
                }
                offset -= 1;
            } else {
                if lex.offset() == offset {
                    return None;
                }
            }
            _take_action!(lex, offset, context, state)
        }
        fn state1<'a, 'b, 'c, 'd>(
            lex: &mut _Lexer<'b, Token<'a, 'b, 'c, 'd>>,
            mut offset: usize,
            mut context: _Option<LogosLeaf>,
        ) -> _Option<
            _Result<Token<'a, 'b, 'c, 'd>, <Token<'a, 'b, 'c, 'd> as Logos<'b>>::Error>,
        > {
            lex.end(offset);
            context = Some(LogosLeaf::Leaf3);
            let other = lex.read::<u8>(offset);
            if let Some(byte) = other {} else {}
            _take_action!(lex, offset, context, state)
        }
        fn state2<'a, 'b, 'c, 'd>(
            lex: &mut _Lexer<'b, Token<'a, 'b, 'c, 'd>>,
            mut offset: usize,
            mut context: _Option<LogosLeaf>,
        ) -> _Option<
            _Result<Token<'a, 'b, 'c, 'd>, <Token<'a, 'b, 'c, 'd> as Logos<'b>>::Error>,
        > {
            lex.end(offset);
            context = Some(LogosLeaf::Leaf0);
            let other = lex.read::<u8>(offset);
            if let Some(byte) = other {} else {}
            _take_action!(lex, offset, context, state)
        }
        fn state3<'a, 'b, 'c, 'd>(
            lex: &mut _Lexer<'b, Token<'a, 'b, 'c, 'd>>,
            mut offset: usize,
            mut context: _Option<LogosLeaf>,
        ) -> _Option<
            _Result<Token<'a, 'b, 'c, 'd>, <Token<'a, 'b, 'c, 'd> as Logos<'b>>::Error>,
        > {
            lex.end(offset);
            context = Some(LogosLeaf::Leaf1);
            let other = lex.read::<u8>(offset);
            if let Some(byte) = other {} else {}
            _take_action!(lex, offset, context, state)
        }
        fn state4<'a, 'b, 'c, 'd>(
            lex: &mut _Lexer<'b, Token<'a, 'b, 'c, 'd>>,
            mut offset: usize,
            mut context: _Option<LogosLeaf>,
        ) -> _Option<
            _Result<Token<'a, 'b, 'c, 'd>, <Token<'a, 'b, 'c, 'd> as Logos<'b>>::Error>,
        > {
            lex.end(offset);
            context = Some(LogosLeaf::Leaf2);
            let other = lex.read::<u8>(offset);
            if let Some(byte) = other {} else {}
            _take_action!(lex, offset, context, state)
        }
        state0(lex, lex.offset(), None)
    }
