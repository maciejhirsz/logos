                    CallbackRetVal::<
                        'b,
                        &'a str,
                        Token<'a, 'b, 'c, 'd>,
                    >::construct(cb_result, Token::A)
                }
                _Option::Some(LogosLeaf::Leaf1) => {
                    let token = Token::B(lex.slice());
                    CallbackResult::Emit(token)
                }
                _Option::Some(LogosLeaf::Leaf2) => {
                    let cb_result = {
                        let lex = lex;
                        &lex.extras.1[9]
                    };
                    CallbackRetVal::<
                        'b,
